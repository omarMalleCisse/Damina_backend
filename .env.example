# Copier en .env et remplir. Sur Railway, définir ces variables dans le dashboard.

# --- Base de données Railway MySQL ---
# Railway injecte MYSQL_URL ou MYSQL_PUBLIC_URL (Add Variable Reference depuis le service MySQL).
# Format Railway : mysql://${{MYSQLUSER}}:${{MYSQL_ROOT_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:3306/${{MYSQL_DATABASE}}
# Le backend convertit automatiquement mysql:// en mysql+pymysql://.
# Ou définir manuellement :
# DATABASE_URL=mysql+pymysql://user:password@host:3306/database
# Ou séparément :
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=broderie_db

# --- Sécurité ---
SECRET_KEY=votre_secret_key_long_et_aleatoire
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS & Frontend (obligatoire en prod) ---
FRONTEND_URL=https://damina-8mwqxw2tp-omarmallecisses-projects.vercel.app
# Ou liste d'origines séparées par des virgules :
# CORS_ORIGINS=https://votre-app.vercel.app,https://www.daminaplus.com

# --- PayTech (paiement) ---
# PAYTECH_API_KEY=
# PAYTECH_SIGNING_KEY=
# PAYTECH_IPN_URL=https://votre-backend.railway.app/api/payments/webhook
# PAYTECH_SANDBOX=false

# --- Optionnel (Railway définit PORT automatiquement) ---
# PORT=8000
# ENV=production
