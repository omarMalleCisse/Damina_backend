# Copier en .env et remplir. Sur Railway, définir ces variables dans le dashboard.

# --- Base de données (Railway MySQL fournit DATABASE_URL) ---
DATABASE_URL=mysql+pymysql://user:password@host:3306/database
# Ou séparément :
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=broderie_db

# --- Sécurité ---
SECRET_KEY=votre_secret_key_long_et_aleatoire
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS & Frontend (obligatoire en prod) ---
FRONTEND_URL=https://votre-app.vercel.app
# Ou liste d'origines séparées par des virgules :
# CORS_ORIGINS=https://votre-app.vercel.app,https://www.daminaplus.com

# --- PayTech (paiement) ---
# PAYTECH_API_KEY=
# PAYTECH_SIGNING_KEY=
# PAYTECH_IPN_URL=https://votre-backend.railway.app/api/payments/webhook
# PAYTECH_SANDBOX=false

# --- Optionnel (Railway définit PORT automatiquement) ---
# PORT=8000
# ENV=production
